{
  "compilerOptions": {
    // "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "isolatedModules": true,

    "skipLibCheck": true
  },

  "include": ["src/**/*", "prisma.config.ts"]
}
