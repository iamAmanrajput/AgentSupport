generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ENUMS

// Tiers for custom subscription plan checks
enum SubscriptionPlan {
  FREE
  PRO
}

// Transaction billing states
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INACTIVE
}

// Support ticket states for lifecycle workflow
enum ConversationStatus {
  UNASSIGNED // New customer ticket created, waiting for first action
  UNRESOLVED // Ticket is active, customer is chatting with the AI agent
  ESCALATED  // AI is paused, control is handed over to human operators
  RESOLVED   // Ticket is closed/resolved, widget and dashboard inputs are locked
}

// Sender identity of individual chat bubbles
enum MessageRole {
  USER      // Customer / Web Visitor
  ASSISTANT // Support Operator or AI Agent response
  SYSTEM    // System logs (e.g. "Conversation resolved")
  TOOL      // AI search tool metadata payloads
}

// Uploaded file ingestion processing stages
enum KnowledgeBaseEntryStatus {
  PENDING // File is uploaded, waiting to extract text and embed vectors
  READY   // Vectors created, document ready for semantic search
  ERROR   // Document extraction failed
}

enum InviteStatus {
  PENDING
  ACCEPTED
}


// AUTHENTICATION & TEAM MODELS

// Platform owner — creates projects and manages operators
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscription     Subscription?
  createdProjects  Project[]  @relation("AdminProjects")
  createdOperators Operator[] @relation("AdminOperators")

  @@map("admins")
}

// Team member invited by admin to handle escalated conversations
model Operator {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  token        String       @unique     // Secure random token — email link
  status       InviteStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  adminId String
  admin   Admin  @relation("AdminOperators", fields: [adminId], references: [id], onDelete: Cascade)

  projectAssignments    ProjectAssignment[]
  assignedConversations Conversation[]      @relation("AssignedConversations")

  @@index([adminId])
  @@map("operators")
}


// PROJECT & ORGANIZATION ISOLATION

// Logical workspace — isolates widget, conversations, and knowledge base
model Project {
  id          String   @id @default(cuid())
  name        String
  widgetToken String   @unique @default(cuid()) // Unique token for widget script tag
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId String
  creator   Admin  @relation("AdminProjects", fields: [creatorId], references: [id])

  operators        ProjectAssignment[]
  widgetSettings   WidgetSettings?
  contactSessions  ContactSession[]
  conversations    Conversation[]
  threads          Thread[]
  knowledgeEntries KnowledgeBaseEntry[]
  storageFiles     StorageFile[]

  @@unique([creatorId, name])
  @@index([creatorId])
  @@map("projects")
}

// Junction table — maps operators to projects (many-to-many)
model ProjectAssignment {
  id         String   @id @default(cuid())
  projectId  String
  operatorId String
  assignedAt DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([projectId, operatorId])
  @@map("project_assignments")
}


// BILLING & SUBSCRIPTIONS

// One subscription per admin — tracks plan, limits, and Razorpay state
model Subscription {
  id                     String             @id @default(cuid())
  adminId                String             @unique
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(INACTIVE)
  maxProjects            Int                @default(2)  // FREE: 2, PRO: 10
  maxOperators           Int                @default(1)  // FREE: 1, PRO: 5
  expiresAt              DateTime?
  razorpaySubscriptionId String?            @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}


// WIDGET CONFIGURATION

// Per-project chat widget UI settings (greeting, quick-reply suggestions)
model WidgetSettings {
  id           String   @id @default(cuid())
  projectId    String   @unique
  greetMessage String
  suggestions  String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("widget_settings")
}

// SUPPORT TICKETS & CHATS

// Anonymous guest customer profile — created on widget load, expires after session
model ContactSession {
  id        String   @id @default(cuid())
  projectId String
  name      String
  email     String
  expiresAt DateTime
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([projectId])
  @@index([expiresAt])
  @@index([email])
  @@map("contact_sessions")
}

// Support ticket — one per contact session, links to a thread of messages
model Conversation {
  id               String             @id @default(cuid())
  projectId        String
  contactSessionId String
  threadId         String             @unique
  status           ConversationStatus @default(UNASSIGNED)
  assignedOperatorId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactSession   ContactSession @relation(fields: [contactSessionId], references: [id], onDelete: Restrict)
  thread           Thread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  assignedOperator Operator?      @relation("AssignedConversations", fields: [assignedOperatorId], references: [id], onDelete: SetNull)

  @@index([assignedOperatorId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([status, projectId, createdAt(sort: Desc)])
  @@map("conversations")
}

// Container for all messages in a conversation — also stores AI-generated summary
model Thread {
  id        String   @id @default(cuid())
  projectId String
  title     String?
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation?
  messages     Message[]

  @@index([projectId])
  @@map("threads")
}

// Individual chat bubble — role determines rendering and routing logic
model Message {
  id          String      @id @default(cuid())
  threadId    String
  role        MessageRole
  textContent String?     @db.Text
  payload     Json?       // Used by TOOL role for structured metadata
  agentName   String?
  createdAt   DateTime    @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt(sort: Asc)])
  @@map("messages")
}


// FILE STORAGE (CLOUDINARY)

// Tracks every file uploaded to Cloudinary — referenced by knowledge base entries
model StorageFile {
  id        String   @id @default(cuid())
  projectId String
  filename  String
  mimeType  String
  sizeBytes BigInt
  publicId  String   @unique
  secureUrl String   @db.Text
  createdAt DateTime @default(now())

  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeEntries KnowledgeBaseEntry[]

  @@index([projectId])
  @@map("storage_files")
}

// KNOWLEDGE BASE (RAG)

// Uploaded document registered for RAG — tracks ingestion status per project
model KnowledgeBaseEntry {
  id            String                   @id @default(cuid())
  projectId     String
  storageFileId String?
  filename      String
  contentHash   String?                  // Duplicate PDF detection
  category      String?
  status        KnowledgeBaseEntryStatus @default(PENDING)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storageFile StorageFile? @relation(fields: [storageFileId], references: [id], onDelete: SetNull)
  chunks      KnowledgeBaseChunk[]

  @@unique([projectId, contentHash])
  @@index([projectId, status])
  @@map("knowledge_base_entries")
}

// Text chunk split from a knowledge base entry — holds Qdrant vector point reference
model KnowledgeBaseChunk {
  id            String   @id @default(cuid())
  entryId       String
  chunkIndex    Int
  content       String   @db.Text
  qdrantPointId String?  @unique // Qdrant vector store point ID — null until PENDING clears
  createdAt     DateTime @default(now())

  entry KnowledgeBaseEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, chunkIndex])
  @@map("knowledge_base_chunks")
}
